{
    "name": "buckhamduffy/laravel-xero-practice-manager",
    "description": "SDK for Xero Practice Manager API",
    "license": "MIT",
    "keywords": [
        "buckhamduffy",
        "laravel",
        "xero",
        "practice-manager",
        "saloon",
        "xml",
        "api",
        "sdk"
    ],
    "authors": [
        {
            "name": "Aaron Florey",
            "email": "aaron@buckhamduffy.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/buckhamduffy/laravel-xero-practice-manager",
    "require": {
        "php": "8.5.6",
        "ext-simplexml": "*",
        "illuminate/contracts": "12.61.0",
        "saloonphp/cache-plugin": "3.1.0",
        "saloonphp/laravel-http-sender": "3.1.0",
        "saloonphp/laravel-plugin": "3.11.0",
        "saloonphp/rate-limit-plugin": "2.5.1",
        "saloonphp/saloon": "3.15.0",
        "spatie/array-to-xml": "3.4.4",
        "spatie/laravel-data": "4.23.0",
        "spatie/laravel-package-tools": "1.93.1",
        "xeroapi/xero-php-oauth2": "2.23.3"
    },
    "require-dev": {
        "buckhamduffy/coding-standards": "7.0.3",
        "ergebnis/composer-normalize": "2.52.0",
        "irazasyed/docgen": "0.2.0",
        "nunomaduro/collision": "8.9.4",
        "orchestra/testbench": "10.11.0",
        "pestphp/pest": "3.8.6",
        "pestphp/pest-plugin-arch": "3.1.1",
        "pestphp/pest-plugin-laravel": "3.2.0",
        "spatie/laravel-ray": "1.43.9"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "BuckhamDuffy\\LaravelXeroPracticeManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BuckhamDuffy\\LaravelXeroPracticeManager\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "captainhook/plugin-composer": true,
            "captainhook/hook-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "aliases": {
                "LaravelXeroPracticeManager": "BuckhamDuffy\\LaravelXeroPracticeManager\\Facades\\LaravelXeroPracticeManager"
            },
            "providers": [
                "BuckhamDuffy\\LaravelXeroPracticeManager\\LaravelXeroPracticeManagerServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    }
}
